---
import BaseLayout from '../../layouts/BaseLayout.astro';
import about from '../../content/pages/en/about.json';
---

<BaseLayout title="About Us | Pugliesi nel Mondo UK" currentPath="/en/about" lang="en">
  <div class="page-layout">
    <h1>{about.title}</h1>
    <p class="intro">{about.intro}</p>

    {about.sections.map((section) => (
      <div class="page-section">
        <h2>{section.title}</h2>
        <p>{section.text}</p>
      </div>
    ))}
  </div>
</BaseLayout>
