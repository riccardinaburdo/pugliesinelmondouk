---
import BaseLayout from '../../layouts/BaseLayout.astro';
import home from '../../content/pages/en/home.json';
import fs from 'node:fs';
import path from 'node:path';

const eventsDir = path.join(process.cwd(), 'src/content/events/en');
const eventFiles = fs.readdirSync(eventsDir).filter(f => f.endsWith('.json'));
const events = eventFiles
  .map(f => JSON.parse(fs.readFileSync(path.join(eventsDir, f), 'utf-8')))
  .filter(e => e.status === 'upcoming')
  .sort((a, b) => new Date(a.date).getTime() - new Date(b.date).getTime());
---

<BaseLayout title="Pugliesi nel Mondo UK" currentPath="/en" lang="en">
  <section class="hero-image">
    <img src="/images/general/hero.jpg" alt="Puglia and London - Pugliesi nel Mondo UK" />
    <div class="hero-overlay">
      <h1>{home.hero.title}</h1>
      <p class="subtitle">{home.hero.subtitle}</p>
      <p class="description">{home.hero.description}</p>
      <a href="/en/membership" class="btn-primary">Become a Member</a>
    </div>
  </section>

  <section class="section">
    <h2 class="section-title">{home.mission.title}</h2>
    <p style="text-align: center; max-width: 750px; margin: 0 auto; font-size: 1.1rem; line-height: 1.8; color: var(--color-gray);">
      {home.mission.text}
    </p>
  </section>

  {events.length > 0 && (
    <section class="section">
      <h2 class="section-title">Upcoming Events</h2>
      <div class="event-video">
        <video controls playsinline preload="metadata">
          <source src="/images/events/fest-video.mp4" type="video/mp4" />
        </video>
      </div>
      <div class="events-list">
        {events.map((event) => (
          <div class="event-card">
            <div class="event-card-body" style="padding: 2rem;">
              <h3>{event.title}</h3>
              <p class="event-date">
                {new Date(event.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
                {event.endDate && ` - ${new Date(event.endDate).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}`}
              </p>
              <p class="event-location">📍 {event.location}</p>
              <p>{event.description}</p>
              <a href={`/en/events/${event.slug}`} class="btn-secondary" style="margin-top: 1rem; display: inline-block;">Learn More</a>
            </div>
          </div>
        ))}
      </div>
    </section>
  )}

  <section class="section-alt">
    <div class="section-inner">
      <h2 class="section-title">{home.whatWeDo.title}</h2>
      <div class="features-grid">
        {home.whatWeDo.items.map((item) => (
          <div class="feature-card">
            <div class="feature-icon">
              {item.icon === 'calendar' && '📅'}
              {item.icon === 'people' && '🤝'}
              {item.icon === 'heart' && '❤️'}
              {item.icon === 'hands' && '🙌'}
            </div>
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
