---
import BaseLayout from '../../layouts/BaseLayout.astro';
import fs from 'node:fs';
import path from 'node:path';

export function getStaticPaths() {
  const eventsDir = path.join(process.cwd(), 'src/content/events');
  const files = fs.readdirSync(eventsDir).filter(f => f.endsWith('.json'));
  return files.map(f => {
    const event = JSON.parse(fs.readFileSync(path.join(eventsDir, f), 'utf-8'));
    return { params: { slug: event.slug }, props: { event } };
  });
}

const { event } = Astro.props;
---

<BaseLayout title={`${event.title} | Pugliesi nel Mondo UK`} currentPath={`/eventi/${event.slug}`}>
  <div class="event-detail">
    <a href="/eventi" style="color: var(--color-primary); display: inline-block; margin-bottom: 2rem;">&larr; Tutti gli Eventi</a>

    <h1>{event.title}</h1>
    <p class="meta">
      📅 {new Date(event.date).toLocaleDateString('it-IT', { day: 'numeric', month: 'long', year: 'numeric' })}
      {event.endDate && ` - ${new Date(event.endDate).toLocaleDateString('it-IT', { day: 'numeric', month: 'long', year: 'numeric' })}`}
      &nbsp;&nbsp; 📍 {event.location}
    </p>

    <!-- Categories -->
    {event.categories && (
      <div class="event-categories">
        {event.categories.map((cat: string) => (
          <span class="event-tag">{cat}</span>
        ))}
      </div>
    )}

    <div class="content">
      {event.longDescription && event.longDescription.map((p: string) => <p>{p}</p>)}
      {!event.longDescription && <p>{event.description}</p>}
    </div>

    <!-- Programme as card grid -->
    {event.programme && event.programme.length > 0 && (
      <div class="programme-section">
        <h2>Programma</h2>
        <div class="programme-grid">
          {event.programme.map((item: any) => (
            <div class="programme-grid-card">
              {item.image ? <img src={item.image} alt={item.title} /> : <div class="programme-placeholder"></div>}
              <div class="programme-card-divider"></div>
              <div class="programme-grid-body">
                <h3>{item.title}</h3>
                {item.category && <p class="programme-grid-category">{item.category}</p>}
                <ul class="programme-grid-meta">
                  <li>
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
                    {new Date(item.date).toLocaleDateString('it-IT', { day: 'numeric', month: 'long', year: 'numeric' })}
                  </li>
                  {item.time && (
                    <li>
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" /></svg>
                      {item.time === 'TBA' ? 'Orario da confermare' : item.time}
                    </li>
                  )}
                  {item.price && (
                    <li>
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="12" y1="1" x2="12" y2="23" /><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6" /></svg>
                      {item.price}
                    </li>
                  )}
                  {item.venue && (
                    <li>
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" /><circle cx="12" cy="10" r="3" /></svg>
                      <span class="venue-link">{item.venue}</span>
                    </li>
                  )}
                </ul>
              </div>
            </div>
          ))}
        </div>
        <p style="text-align: center; color: var(--color-gray); margin-top: 2rem; font-style: italic;">
          Il programma completo sara' pubblicato a breve. Seguici sui social per gli aggiornamenti!
        </p>
      </div>
    )}

    <!-- Highlights (fallback) -->
    {event.highlights && !event.programme && (
      <div class="event-highlights">
        <h3>In Programma</h3>
        <ul>
          {event.highlights.map((h: string) => <li>{h}</li>)}
        </ul>
      </div>
    )}

    <!-- Collaborators -->
    {event.collaborators && (
      <div class="collab-section">
        <h3>In Collaborazione Con</h3>
        <p>{event.collaborators.join(' • ')}</p>
      </div>
    )}

    <!-- Patronage -->
    {event.patronage && (
      <div class="collab-section">
        <h3>Con il Patrocinio di</h3>
        <p>{event.patronage.join(' • ')}</p>
      </div>
    )}

    <!-- Media Partners -->
    {event.mediaPartners && (
      <div class="collab-section">
        <h3>Media Partners</h3>
        <p>{event.mediaPartners.join(' • ')}</p>
      </div>
    )}

    <div style="margin-top: 3rem; text-align: center;">
      <p style="margin-bottom: 1rem; color: var(--color-gray);">Per informazioni, sponsorship e partecipazione:</p>
      <a href="mailto:puglianelmondolondra@gmail.com" class="btn-primary">Contattaci</a>
    </div>
  </div>
</BaseLayout>
